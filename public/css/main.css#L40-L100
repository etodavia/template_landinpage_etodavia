/* Cabeçalho Global Dinâmico */
header {
    position: fixed;
    top: 40px;
    left: 0;
    width: 100%;
    height: 80px;
    background: var(--header-bg, #ffffff); /* Usa a variável do painel */
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8%;
    z-index: 1000;
    transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 30px rgba(0,0,0,0.03);
}

header.scrolled {
    top: 0;
    height: 70px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
}

.logo img {
    height: 35px;
    width: auto;
}

/* Links do Menu usando a Cor do Texto do Painel */
.nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
}

.nav-links a {
    text-decoration: none;
    color: var(--text-color, #333333); /* Usa a cor do texto definida no painel */
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: 0.3s;
    position: relative;
}

.nav-links a::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-red);
    transition: 0.3s;
}

.nav-links a:hover {
    color: var(--accent-red);
}

.nav-links a:hover::after {
    width: 100%;
}

/* Botão Agendar Consulta */
.btn-cta {
    background: var(--accent-red);
    color: white !important;
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 0.85rem;
    text-decoration: none;
    transition: 0.3s;
    border: 2px solid var(--accent-red);
}

.btn-cta:hover {
    background: transparent;
    color: var(--accent-red) !important;
}

@media (max-width: 1024px) {
    .nav-links { display: none; } /* Hamburger menu logic here if implemented */
}
