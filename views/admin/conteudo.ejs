            document.getElementById('beneficiosJsonData').value = JSON.stringify(beneficiosList);
        };

        window.addNewBeneficio = function() {
            beneficiosList.push({ icone: 'ri-checkbox-circle-line', titulo: '', texto: '' });
            renderBeneficios();
        };

        window.removeBeneficio = function(index) {
            if(confirm('Tem certeza que deseja remover este benefício?')) {
                beneficiosList.splice(index, 1);
                renderBeneficios();
            }
        };

