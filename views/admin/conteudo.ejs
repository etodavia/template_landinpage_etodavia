            { id: 'destaque', name: 'Destaque Paralaxe (Fixo/Zoom)', active: true, icon: 'ri-focus-3-line' },
            { id: 'depoimentos', name: 'Depoimentos / Avaliações', active: true, icon: 'ri-chat-quote-line' },
            { id: 'contato', name: 'Contato Home / Dados e Mapa', active: true, icon: 'ri-contacts-book-2-line' }
