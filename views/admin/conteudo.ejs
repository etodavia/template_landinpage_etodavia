<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= settings.site_name || 'Sistema' %></title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <style>
        .cms-layout { display: flex; overflow: hidden; background: #F8FAFC; transition: 0.4s; }
        .cms-tabs-nav { 
            width: 280px; background: white; border-right: 1px solid #eee; 
            padding: 20px 0; overflow-y: auto; flex-shrink: 0; 
            transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
        }
        .cms-tabs-nav.collapsed { width: 85px; }
        .cms-tabs-nav.collapsed .tab-link span, 
        .cms-tabs-nav.collapsed .tab-category-header { display: none; }
        .cms-tabs-nav.collapsed .tab-link { justify-content: center; padding: 15px 0; border-right-width: 4px; }
        .cms-tabs-nav.collapsed .tab-link i { font-size: 1.4rem; margin: 0; }

        .tab-link { padding: 12px 30px; cursor: pointer; display: flex; align-items: center; gap: 12px; color: #64748b; font-size: 0.9rem; font-weight: 600; border-right: 3px solid transparent; transition: 0.3s; }
        .tab-link:hover { color: var(--primary); background: #F1F5F9; }
        .tab-link.active { color: var(--primary); background: #F1F5F9; border-right-color: var(--accent); }
        .tab-link i { font-size: 1.1rem; opacity: 0.7; }
        .tab-category-header { font-size: 0.65rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; padding: 20px 30px 10px; }
        .cms-content { flex: 1; padding: 40px; overflow-y: auto; background: white; transition: 0.4s; }
        .tab-panel { display: none; max-width: 900px; margin: 0 auto; }
        .tab-panel.active { display: block; animation: slideUp 0.4s ease-out; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Botão de Encolher Submenu */
        .btn-collapse-sub {
            position: absolute; top: 10px; right: 10px; 
            width: 25px; height: 25px; border-radius: 50%;
            background: #f1f5f9; color: #64748b; border: none;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; z-index: 10; transition: 0.3s;
        }
        .btn-collapse-sub:hover { background: var(--accent); color: white; }

        /* RESPONSIVIDADE MULTI-DISPOSITIVO (TABLET & MOBILE) */
        @media (max-width: 992px) {
            .cms-layout { flex-direction: column; height: auto !important; }
            .cms-tabs-nav { 
                width: 100% !important; height: auto; display: flex; flex-direction: row !important; flex-wrap: nowrap !important; overflow-x: auto; 
                padding: 5px 10px; border-right: none; border-bottom: 1px solid #eee; 
                white-space: nowrap; scrollbar-width: none; -ms-overflow-style: none;
                background: #f8fafc; gap: 5px; align-items: center;
            }
            .cms-tabs-nav.collapsed { width: 100% !important; }
            .btn-collapse-sub { display: none; }
            .cms-tabs-nav span { display: inline !important; font-size: 0.75rem; }
            .cms-tabs-nav::-webkit-scrollbar { display: none; }
            .tab-category-header { display: none; }
            .tab-link { 
                padding: 10px 15px !important; border-right: none !important; border-bottom: 2px solid transparent; border-left: none !important;
                flex-direction: column; gap: 4px; text-align: center; min-width: 80px; margin-bottom: 0 !important;
                flex-shrink: 0; /* IMPEDE QUE OS TEXTOS SE ESPREMEM */
            }
            .scroll-hint-mobile { display: flex !important; }
            .tab-link i { font-size: 1.2rem; }
            .tab-link.active { border-bottom-color: var(--accent) !important; background: white !important; }
            .cms-content { padding: 20px; }
            
            /* FORÇAR GRIDS INLINE A 1 COLUNA NO MOBILE */
            .cms-content [style*="grid-template-columns"] { grid-template-columns: 1fr !important; }
        }
        .scroll-hint-mobile { display: none; background: #f1f5f9; color: #64748b; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; text-align: center; padding: 8px; align-items: center; justify-content: center; gap: 5px; border-bottom: 1px solid #eee; letter-spacing: 1px; }
    </style>
</head>
<body>
    <div class="admin-app">
        <datalist id="iconSuggestions">
            <option value="ri-rocket-line">Foguete (Agilidade/Lançamento)</option>
            <option value="ri-medal-line">Medalha (Qualidade/Excelência)</option>
            <option value="ri-shield-check-line">Escudo (Segurança/Confiança)</option>
            <option value="ri-team-line">Time (Colaboração/Pessoas)</option>
            <option value="ri-customer-service-2-line">Atendimento (Suporte/SAC)</option>
            <option value="ri-global-line">Globo (Internacional/Abrangência)</option>
            <option value="ri-lightbulb-line">Lâmpada (Inovação/Ideias)</option>
            <option value="ri-honour-line">Honra (Ética/Valores)</option>
            <option value="ri-focus-2-line">Foco (Objetividade/Precisão)</option>
            <option value="ri-briefcase-line">Maleta (Gestão/Corporativo)</option>
            <option value="ri-line-chart-line">Gráfico (Resultados/Crescimento)</option>
            <option value="ri-thumb-up-line">Like (Satisfação/Aprovação)</option>
            <option value="ri-user-star-line">Estrela (Exclusividade/VIP)</option>
            <option value="ri-service-line">Serviço (Manutenção/Especialidade)</option>
            <option value="ri-shake-hands-line">Parceria/Acordo</option>
            <option value="ri-timer-line">Relógio (Pontualidade/Prazo)</option>
            <option value="ri-award-line">Prêmio (Reconhecimento)</option>
            <option value="ri-check-line">Check (Conclusão)</option>
        </datalist>
        <%
            const hasTab = (t) => locals.userRole === 'superadmin' || (locals.userPermissions && locals.userPermissions.includes(t));
            
            // Encontrar a primeira aba permitida
            const defaultTabsList = [
                'tab-licenciamento', 'tab-identidade', 'tab-header', 'tab-whatsapp', 'tab-redes', 'tab-seo',
                'tab-admin-branding', 'tab-login-branding', 'tab-layout-builder', 'tab-home-hero', 'tab-home-sobre',
                'tab-home-servicos', 'tab-home-popup', 'tab-home-beneficios', 'tab-home-destaque', 'tab-home-depoimentos', 'tab-home-contato',
                'tab-footer', 'tab-legal-pages'
            ];
            let firstAllowedTab = '';
            for (const t of defaultTabsList) {
                if (hasTab(t)) {
                    if (t === 'tab-licenciamento' && locals.userRole !== 'superadmin') continue;
                    if (t === 'tab-admin-branding' && locals.userRole !== 'superadmin') continue;
                    if (t === 'tab-login-branding' && locals.userRole !== 'superadmin') continue;
                    firstAllowedTab = t;
                    break;
                }
            }
        %>
        <%- include('../partials/admin-sidebar') %>
        
        <div class="admin-main">
            <%- include('../partials/admin-header') %>
            
            <div class="cms-layout">
            <div class="scroll-hint-mobile"><i class="ri-drag-move-fill"></i> Deslize para os lados para ver mais opções <i class="ri-arrow-right-line"></i></div>
            <nav class="cms-tabs-nav" id="cmsSubNav">
                <button type="button" class="btn-collapse-sub" onclick="toggleSubNav()"><i class="ri-arrow-left-right-line"></i></button>

                <% if (locals.userRole === 'superadmin') { %>
                <div class="tab-category-header">Soberania</div>
                <div class="tab-link active" onclick="switchTab('tab-licenciamento')" style="border-left: 4px solid var(--accent); background: rgba(214, 40, 40, 0.05); color: var(--accent); font-weight: 900; margin-bottom: 20px;"><i class="ri-shield-keyhole-fill"></i> <span>Licenciamento (Elite)</span></div>
                <% } %>

                <% if (hasTab('tab-identidade') || hasTab('tab-header') || hasTab('tab-whatsapp') || hasTab('tab-redes') || hasTab('tab-seo') || (locals.userRole === 'superadmin' && (hasTab('tab-admin-branding') || hasTab('tab-login-branding')))) { %>
                <div class="tab-category-header">Global</div>
                <% if (hasTab('tab-identidade')) { %>
                <div class="tab-link" onclick="switchTab('tab-identidade')"><i class="ri-fingerprint-line"></i> <span>Identidade & Cores</span></div>
                <% } %>
                <% if (hasTab('tab-header')) { %>
                <div class="tab-link" onclick="switchTab('tab-header')"><i class="ri-layout-top-line"></i> <span>Cabeçalho</span></div>
                <% } %>
                <% if (hasTab('tab-whatsapp')) { %>
                <div class="tab-link" onclick="switchTab('tab-whatsapp')"><i class="ri-whatsapp-line"></i> <span>WhatsApp</span></div>
                <% } %>
                <% if (hasTab('tab-redes')) { %>
                <div class="tab-link" onclick="switchTab('tab-redes')"><i class="ri-share-line"></i> <span>Redes Sociais</span></div>
                <% } %>
                <% if (hasTab('tab-seo')) { %>
                <div class="tab-link" onclick="switchTab('tab-seo')"><i class="ri-search-line"></i> <span>SEO & Marketing</span></div>
                <% } %>
                <% if (locals.userRole === 'superadmin' && hasTab('tab-admin-branding')) { %>
                <div class="tab-link" onclick="switchTab('tab-admin-branding')" style="color: #4338ca;"><i class="ri-palette-line"></i> <span>Branding do Painel</span></div>
                <% } %>
                <% if (locals.userRole === 'superadmin' && hasTab('tab-login-branding')) { %>
                <div class="tab-link" onclick="switchTab('tab-login-branding')" style="color: #ea580c;"><i class="ri-login-box-line"></i> <span>Customizar Login</span></div>
                <% } %>
                <% } %>

                <% if (hasTab('tab-layout-builder') || hasTab('tab-home-hero') || hasTab('tab-home-sobre') || hasTab('tab-home-servicos') || hasTab('tab-home-popup') || hasTab('tab-home-beneficios') || hasTab('tab-home-depoimentos') || hasTab('tab-home-contato')) { %>
                <div class="tab-category-header">Home Page</div>
                <% if (hasTab('tab-layout-builder')) { %>
                <div class="tab-link" onclick="switchTab('tab-layout-builder')" style="color: #059669; font-weight: 700;"><i class="ri-drag-drop-line"></i> <span>Construtor de Layout</span></div>
                <% } %>
                <% if (hasTab('tab-home-hero')) { %>
                <div class="tab-link" onclick="switchTab('tab-home-hero')"><i class="ri-flashlight-line"></i> <span>Hero</span></div>
                <% } %>
                <% if (hasTab('tab-home-sobre')) { %>
                <div class="tab-link" onclick="switchTab('tab-home-sobre')"><i class="ri-user-3-line"></i> <span>Sobre</span></div>
                <% } %>
                <% if (hasTab('tab-home-servicos')) { %>
                <div class="tab-link" onclick="switchTab('tab-home-servicos')"><i class="ri-briefcase-line"></i> <span>Serviços</span></div>
                <% } %>
                <% if (hasTab('tab-home-popup')) { %>
                <div class="tab-link" onclick="switchTab('tab-home-popup')" style="color: #6d28d9;"><i class="ri-notification-badge-line"></i> <span>Pop-up de Detalhes</span></div>
                <% } %>
                <% if (hasTab('tab-home-beneficios')) { %>
                <div class="tab-link" onclick="switchTab('tab-home-beneficios')"><i class="ri-heart-pulse-line"></i> <span>Benefícios</span></div>
                <% } %>
                <% if (hasTab('tab-home-destaque')) { %>
                <div class="tab-link" onclick="switchTab('tab-home-destaque')" style="color: #ea580c;"><i class="ri-focus-3-line"></i> <span>Destaque Parolaxe</span></div>
                <% } %>
                <% if (hasTab('tab-home-depoimentos')) { %>
                <div class="tab-link" onclick="switchTab('tab-home-depoimentos')"><i class="ri-chat-quote-line"></i> <span>Depoimentos</span></div>
                <% } %>
                <% if (hasTab('tab-home-contato')) { %>
                <div class="tab-link" onclick="switchTab('tab-home-contato')"><i class="ri-contacts-book-2-line"></i> <span>Contato Home</span></div>
                <% } %>
                <% } %>

                <% if (hasTab('tab-footer') || hasTab('tab-legal-pages')) { %>
                <div class="tab-category-header">Estrutura</div>
                <% if (hasTab('tab-footer')) { %>
                <div class="tab-link" onclick="switchTab('tab-footer')"><i class="ri-layout-bottom-line"></i> <span>Rodapé</span></div>
                <% } %>
                <% if (hasTab('tab-legal-pages')) { %>
                <div class="tab-link" onclick="switchTab('tab-legal-pages')"><i class="ri-file-shield-2-line"></i> <span>Páginas Legais</span></div>
                <% } %>
                <% } %>
            </nav>

            <form id="cmsForm" action="/admin/conteudo" method="POST" class="cms-content" enctype="multipart/form-data" novalidate>
                <input type="hidden" name="active_tab" id="activeTabInput" value="<%= (locals.activeTab) ? locals.activeTab : firstAllowedTab %>">
                <div style="max-width: 900px; margin: 0 auto;">
                    <%- include('../partials/admin-alerts') %>
                </div>
                
                <!-- IDENTIDADE & CORES -->
                <div id="tab-identidade" class="tab-panel <%= (locals.userRole !== 'superadmin') ? 'active' : '' %>">
                    <div class="section-header"><h3>Identidade Corporativa</h3></div>
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Nome do Sistema / Título do Site</label>
                            <input type="text" name="site_name" value="<%= settings.site_name || 'Sua Empresa' %>">
                            <p class="field-note"><i class="ri-text"></i> Nome que aparece na aba do navegador ao lado do favicon (SEO e Identidade).</p>
                        </div>
                        <div class="form-group">
                            <label>Logo Principal (Colorida)</label>
                            <input type="file" name="logo_file" accept="image/*">
                            <input type="hidden" name="logo" value="<%= settings.logo %>">
                            <p class="field-note"><i class="ri-image-line"></i> Recomendado: Proporção horizontal, altura ideal de 60px a 100px (PNG ou SVG transparente).</p>
                            <% if (settings.logo) { %> <img src="<%= settings.logo %>" class="img-preview"> <% } %>
                        </div>
                        <div class="form-group">
                            <label>Logo Alternativa (Branca)</label>
                            <input type="file" name="logo_white_file" accept="image/*">
                            <input type="hidden" name="logo_white" value="<%= settings.logo_white %>">
                            <p class="field-note"><i class="ri-image-line"></i> Recomendado: Proporção horizontal, branca com fundo transparente, altura de 60px a 100px.</p>
                            <% if (settings.logo_white) { %> <img src="<%= settings.logo_white %>" class="img-preview"> <% } %>
                        </div>
                        <div class="form-group">
                            <label>Favicon (Ícone Navegador)</label>
                            <input type="file" name="favicon_file" accept="image/*">
                            <input type="hidden" name="favicon" value="<%= settings.favicon %>">
                            <p class="field-note"><i class="ri-image-line"></i> Recomendado: Formato quadrado (1:1), 32x32px ou 48x48px (ICO ou PNG).</p>
                            <% if (settings.favicon) { %> <img src="<%= settings.favicon %>" class="img-preview"> <% } %>
                        </div>
                    </div>

                    <div class="section-header" style="margin-top: 40px;"><h3>Engine de Cores</h3></div>
                    <div class="form-grid">
                        <% 
                            const colors = [
                                { label: 'Navy Blue (Global)', name: 'color_marinho', value: settings.color_marinho || '#0A1128' },
                                { label: 'Areia (Global)', name: 'color_areia', value: settings.color_areia || '#F7F7F4' },
                                { label: 'Destaque / Botões Globais', name: 'color_vermelho', value: settings.color_vermelho || '#D62828' },
                                { label: 'Cor do Botão Hero', name: 'color_hero_button', value: settings.color_hero_button || '' },
                                { label: 'Cor do Texto', name: 'color_texto', value: settings.color_texto || '#333333' },
                                { label: 'Fundo do Cabeçalho', name: 'color_header', value: settings.color_header || '#FFFFFF' },
                                { label: 'Texto do Cabeçalho', name: 'color_header_text', value: settings.color_header_text || '#333333' },
                                { label: 'Fundo do Rodapé', name: 'color_footer', value: settings.color_footer || '#0A1128' },
                                { label: 'Texto do Rodapé', name: 'color_footer_text', value: settings.color_footer_text || '#FFFFFF' },
                                { label: 'Fundo Seção Sobre', name: 'color_about_bg', value: settings.color_about_bg || '#F7F7F4' },

                                { label: 'Fundo Contato/News', name: 'color_contact_bg', value: settings.color_contact_bg || '#F7F7F4' }
                            ]
                        %>

                        <% colors.forEach(color => { %>
                            <div class="form-group">
                                <div class="color-field-container">
                                    <div class="color-swatch-wrapper">
                                        <div class="color-swatch-preview" style="background-color: <%= color.value %>;"></div>
                                        <input type="color" class="color-input-hidden" value="<%= color.value %>">
                                    </div>
                                    <div class="color-info-wrapper">
                                        <span class="color-name-label"><%= color.label %></span>
                                        <input type="text" name="<%= color.name %>" class="color-hex-input" value="<%= color.value.toUpperCase() %>" maxlength="7">
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- CABEÇALHO -->
                <div id="tab-header" class="tab-panel">
                    <div class="section-header"><h3>Configurações do Topo & Marca</h3></div>

                    <div class="form-group full">
                        <label>Estilo do Cabeçalho na Home</label>
                        <select name="header_transparent" style="width: 100%; padding: 12px; border-radius: 50px; border: 1px solid #e0e0e0;">
                            <option value="0" <%= settings.header_transparent == 0 ? 'selected' : '' %>>Sólido (Com cor de fundo)</option>
                            <option value="1" <%= settings.header_transparent == 1 ? 'selected' : '' %>>Transparente (Sobre o Hero)</option>
                        </select>
                    </div>

                    <div class="form-group full">
                        <label>Exibir Topbar (Endereço e Redes no topo)?</label>
                        <select name="show_topbar" style="width: 100%; padding: 12px; border-radius: 50px; border: 1px solid #e0e0e0;">
                            <option value="1" <%= settings.show_topbar == 1 ? 'selected' : '' %>>Sim, exibir topo extra</option>
                            <option value="0" <%= settings.show_topbar == 0 ? 'selected' : '' %>>Não, ocultar topo extra</option>
                        </select>
                    </div>
                    <div class="form-group full">
                        <label>Mensagem da Faixa Superior (Topbar Alert)</label>
                        <input type="text" name="header_strip_text" value="<%= settings.header_strip_text || '' %>" placeholder="Ex: Participe da nossa próxima Mentoria de Liderança!">
                        <p class="field-note"><i class="ri-information-line"></i> Esta mensagem aparecerá na barra preta no topo do site.</p>
                    </div>
                    <div class="form-group full">
                        <label>Endereço à Esquerda</label>
                        <input type="text" name="endereco" value="<%= settings.endereco %>">
                    </div>
                    <div class="form-group full">
                        <label>Botão CTA (Header)</label>
                        <input type="text" name="nav_cta_text" value="<%= settings.nav_cta_text %>">
                    </div>
                    <div class="form-group full">
                        <label>Estrutura do Menu (Um por linha: RÓTULO|LINK)</label>
                            <textarea name="site_menu" rows="6" placeholder="Home | /#home\nSobre | /#sobre\nServiços | /#servicos\nContato | /#contato"><%= settings.site_name ? settings.site_menu : '' %></textarea>
                        <p style="font-size: 0.65rem; color: #999; margin-top: 5px;">Use o formato: Nome|/link. Ex: Contato|/contato</p>
                    </div>

                    <div class="section-header" style="margin-top: 30px;"><h3>Dimensionamento de Textos e Ícones (Topo)</h3></div>
                    <div class="form-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
                        <div class="form-group">
                            <label>Tamanho do Texto do Topbar (rem)</label>
                            <input type="number" step="0.05" name="topbar_font_size" value="<%= settings.topbar_font_size || '0.75' %>">
                            <p class="field-note">Padrão: 0.75rem</p>
                        </div>
                        <div class="form-group">
                            <label>Tamanho dos Ícones do Topbar (rem)</label>
                            <input type="number" step="0.05" name="topbar_icon_size" value="<%= settings.topbar_icon_size || '0.85' %>">
                            <p class="field-note">Padrão: 0.85rem</p>
                        </div>
                        <div class="form-group">
                            <label>Tamanho do Texto do Menu (rem)</label>
                            <input type="number" step="0.05" name="header_font_size" value="<%= settings.header_font_size || '0.90' %>">
                            <p class="field-note">Padrão: 0.90rem</p>
                        </div>
                        <div class="form-group">
                            <label>Tamanho dos Ícones Mobile/Redes (rem)</label>
                            <input type="number" step="0.05" name="header_icon_size" value="<%= settings.header_icon_size || '1.10' %>">
                            <p class="field-note">Padrão: 1.10rem</p>
                        </div>
                    </div>
                </div>

                <!-- WHATSAPP -->
                <div id="tab-whatsapp" class="tab-panel">
                    <div class="section-header"><h3>Configurações do WhatsApp</h3></div>

                    <div class="form-group full">
                        <label>WhatsApp Principal</label>
                        <input type="text" name="whatsapp" value="<%= settings.whatsapp %>" placeholder="Ex: 5521999999999">
                        <p class="field-note"><i class="ri-information-line"></i> Use apenas números com DDD e código do país.</p>
                    </div>
                    <div class="form-group full">
                        <label>Mensagem Padrão do WhatsApp</label>
                        <textarea name="whatsapp_message" rows="4" placeholder="Olá, estive no site e gostaria de agendar uma consulta."><%= settings.whatsapp_message || 'Olá, estive no site e gostaria de agendar uma consulta.' %></textarea>
                        <p class="field-note"><i class="ri-whatsapp-line"></i> Essa frase vai preenchida automaticamente nos botões principais do WhatsApp.</p>
                    </div>
                </div>

                <!-- REDES SOCIAIS -->
                <div id="tab-redes" class="tab-panel">
                    <div class="section-header"><h3>Hub de Canais Sociais (8 Slots)</h3></div>
                    <p style="font-size: 0.8rem; color: #64748B; margin-bottom: 30px;">Configure até 8 redes sociais. Apenas links preenchidos aparecerão no site.</p>
                    
                    <% 
                        let socialLinks = [];
                        try {
                            socialLinks = JSON.parse(settings.social_links || '[]');
                        } catch(e) { socialLinks = []; }
                        while(socialLinks.length < 8) socialLinks.push({ network: '', url: '' });

                        const networks = [
                            { id: 'instagram', label: 'Instagram', icon: 'ri-instagram-line' },
                            { id: 'facebook', label: 'Facebook', icon: 'ri-facebook-fill' },
                            { id: 'linkedin', label: 'LinkedIn', icon: 'ri-linkedin-fill' },
                            { id: 'youtube', label: 'YouTube', icon: 'ri-youtube-fill' },
                            { id: 'tiktok', label: 'TikTok', icon: 'ri-tiktok-fill' },
                            { id: 'twitter', label: 'X (Twitter)', icon: 'ri-twitter-x-fill' },
                            { id: 'pinterest', label: 'Pinterest', icon: 'ri-pinterest-fill' },
                            { id: 'google', label: 'Google Business', icon: 'ri-google-fill' }
                        ];
                    %>

                    <input type="hidden" name="social_links" id="socialLinksData">

                    <div class="social-slots-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
                        <% socialLinks.forEach((slot, idx) => { %>
                            <div class="social-slot-item" style="background: #F8FAFC; padding: 20px; border-radius: 20px; border: 1px solid #E2E8F0;">
                                <div style="display: flex; gap: 10px; flex-direction: column;">
                                    <label style="font-size: 0.65rem; font-weight: 900; color: #94A3B8; text-transform: uppercase;">Slot <%= idx + 1 %></label>
                                    <select class="social-network-select" style="padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0; font-weight: 700; color: var(--primary);">
                                        <option value="">-- Selecionar Rede --</option>
                                        <% networks.forEach(net => { %>
                                            <option value="<%= net.id %>" <%= slot.network === net.id ? 'selected' : '' %>><%= net.label %></option>
                                        <% }) %>
                                    </select>
                                    <input type="text" class="social-url-input" placeholder="https://..." value="<%= slot.url %>" style="padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0;">
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
                
                <!-- SEO & MARKETING -->
                <div id="tab-seo" class="tab-panel">
                    <div class="section-header"><h3>SEO & Estratégia de Marketing</h3></div>
                    
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Meta Title (Página Inicial)</label>
                            <input type="text" name="meta_title_home" value="<%= settings.meta_title_home %>" placeholder="Título que aparece no Google">
                        </div>
                        <div class="form-group full">
                            <label>Meta Description (Página Inicial)</label>
                            <textarea name="meta_description_home" rows="3" placeholder="Resumo do site para os buscadores"><%= settings.meta_description_home %></textarea>
                        </div>
                        <div class="form-group full">
                            <label>Imagem de Destaque do Link (WhatsApp / Redes)</label>
                            <input type="file" name="seo_share_image_file" accept="image/*">
                            <input type="hidden" name="seo_share_image" value="<%= settings.seo_share_image %>">
                            <% if (settings.seo_share_image) { %> <img src="<%= settings.seo_share_image %>" class="img-preview"> <% } %>
                            <label style="display: flex; align-items: center; gap: 8px; margin-top: 10px; font-size: 0.8rem; color: #ef4444; font-weight: 800;">
                                <input type="checkbox" name="seo_share_image_remove" value="1"> Remover imagem atual
                            </label>
                            <p class="field-note"><i class="ri-image-line"></i> Recomendado: 1200x630px. Essa imagem aparece na prévia do link no WhatsApp.</p>
                        </div>
                        <div class="form-group full">
                            <label>Keywords (Palavras-chave separadas por vírgula)</label>
                            <input type="text" name="meta_keywords" value="<%= settings.meta_keywords %>" placeholder="consultoria, rh, gestão, etc">
                        </div>

                        <div class="section-header" style="margin-top: 40px;"><h4>Rastreamento e Pixels</h4></div>
                        
                        <div class="form-group">
                            <label>Google Analytics ID</label>
                            <input type="text" name="google_analytics" value="<%= settings.google_analytics %>" placeholder="UA-XXXXX-Y ou G-XXXXXXX">
                        </div>
                        <div class="form-group">
                            <label>Facebook Pixel ID</label>
                            <input type="text" name="facebook_pixel" value="<%= settings.facebook_pixel %>" placeholder="Ex: 123456789012345">
                        </div>
                        <div class="form-group">
                            <label>Pinterest Tag ID</label>
                            <input type="text" name="pinterest_pixel" value="<%= settings.pinterest_pixel %>" placeholder="Ex: 261XXXXXXXXXX">
                        </div>
                        <div class="form-group">
                            <label>LinkedIn Insight ID</label>
                            <input type="text" name="linkedin_pixel" value="<%= settings.linkedin_pixel %>" placeholder="Ex: 1234567">
                        </div>

                        <div class="section-header" style="margin-top: 40px;"><h4>Scripts Customizados (Tag Manager / APIs)</h4></div>
                        
                        <div class="form-group full">
                            <label>Scripts no Cabeçalho (Dentro do &lt;head&gt;)</label>
                            <textarea name="custom_head_code" rows="5" placeholder="Cole aqui scripts do Google Tag Manager, Verificação de Domínio, etc"><%= settings.custom_head_code %></textarea>
                            <p class="field-note"><i class="ri-warning-line"></i> Use com cuidado. Códigos mal formatados podem quebrar o site.</p>
                        </div>
                        <div class="form-group full">
                            <label>Scripts no Início do Corpo (Logo após &lt;body&gt;)</label>
                            <textarea name="custom_body_code" rows="5" placeholder="Cole aqui scripts de NoScript, Chatbots, etc"><%= settings.custom_body_code %></textarea>
                        </div>
                    </div>
                </div>
                
                <% if (locals.userRole === 'superadmin') { %>
                <!-- BRANDING DO PAINEL (WHITE LABEL) -->
                <div id="tab-admin-branding" class="tab-panel">
                    <div class="section-header"><h3>Branding do Painel de Controle <span style="background: #4338ca; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.6rem;">WHITE LABEL</span></h3></div>
                    <p style="font-size: 0.8rem; color: #64748B; margin-bottom: 30px;">Personalize a interface administrativa para cada cliente. Estas cores e logos afetam apenas o ambiente de gestão.</p>
                    
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Logo do Dashboard (Exibida na Sidebar - Fundo Escuro)</label>
                            <input type="file" name="admin_logo_file" accept="image/*">
                            <input type="hidden" name="admin_logo" value="<%= settings.admin_logo %>">
                            <p class="field-note"><i class="ri-information-line"></i> Recomendado: Logo Branca/Vazada horizontal, altura de 50px a 70px.</p>
                            <% if (settings.admin_logo) { %> <img src="<%= settings.admin_logo %>" class="img-preview" style="background: #0A1128; padding: 10px;"> <% } %>
                        </div>

                        <div class="form-group full">
                            <label>Logo do Topo (Exibida no Cabeçalho - Fundo Claro)</label>
                            <input type="file" name="admin_header_logo_file" accept="image/*">
                            <input type="hidden" name="admin_header_logo" value="<%= settings.admin_header_logo %>">
                            <p class="field-note"><i class="ri-information-line"></i> Recomendado: Logo Colorida/Dark horizontal, altura de 40px a 60px.</p>
                            <% if (settings.admin_header_logo) { %> <img src="<%= settings.admin_header_logo %>" class="img-preview" style="background: #FFFFFF; padding: 10px; border: 1px solid #eee;"> <% } %>
                        </div>

                        <div class="form-group">
                            <label>Cor Primária do Painel (Sidebar/Botões)</label>
                            <div class="color-field-container">
                                <div class="color-swatch-wrapper">
                                    <div class="color-swatch-preview" style="background-color: <%= settings.admin_primary_color || '#0A1128' %>"></div>
                                    <input type="color" class="color-input-hidden" name="admin_primary_color" value="<%= settings.admin_primary_color || '#0A1128' %>">
                                </div>
                                <div class="color-info-wrapper">
                                    <span class="color-name-label">Primary Admin</span>
                                    <input type="text" class="color-hex-input" value="<%= settings.admin_primary_color || '#0A1128' %>">
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Cor de Destaque (Accent)</label>
                            <div class="color-field-container">
                                <div class="color-swatch-wrapper">
                                    <div class="color-swatch-preview" style="background-color: <%= settings.admin_accent_color || '#D62828' %>"></div>
                                    <input type="color" class="color-input-hidden" name="admin_accent_color" value="<%= settings.admin_accent_color || '#D62828' %>">
                                </div>
                                <div class="color-info-wrapper">
                                    <span class="color-name-label">Accent Admin</span>
                                    <input type="text" class="color-hex-input" value="<%= settings.admin_accent_color || '#D62828' %>">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div style="margin-top: 40px; padding: 25px; background: #EEF2FF; border-radius: 20px; border: 1px solid #C7D2FE; color: #4338ca;">
                        <h4 style="font-size: 0.85rem; font-weight: 800; margin-bottom: 10px; display: flex; align-items: center; gap: 8px;">
                            <i class="ri-lightbulb-line"></i> DICA DE REUSO
                        </h4>
                        <p style="font-size: 0.75rem; line-height: 1.6; font-weight: 500;">
                            Ao configurar um novo cliente, você pode alterar essas cores para combinar com a marca dele, dando uma sensação de plataforma exclusiva. Isso valoriza a sua entrega como agência.
                        </p>
                    </div>
                </div>
                <% } %>

                <!-- CONSTRUTOR DE LAYOUT (ELEMENTOR-STYLE) -->
                <div id="tab-layout-builder" class="tab-panel">
                    <div class="section-header">
                        <h3>Construtor de Layout (Elementor-Style)</h3>
                        <p style="font-size: 0.8rem; color: #64748b; margin-top: 5px;">Organize a ordem, visibilidade e estilo das seções da sua Home Page. O modelo perfeito da empresa para qualquer cliente.</p>
                    </div>

                    <div style="background: white; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); border: 1px solid #e2e8f0; padding: 25px; margin-bottom: 20px;">
                        <div id="layout-builder-container" style="display: grid; gap: 15px; margin-bottom: 20px;">
                            <!-- Carregado via JS -->
                        </div>

                        <input type="hidden" name="layout_secoes" id="layout_secoes_json" value="<%= settings.layout_secoes || '' %>">
                        <input type="hidden" name="estilo_secoes" id="estilo_secoes_json" value="<%= settings.estilo_secoes || '' %>">
                    </div>

                    <!-- TIPOGRAFIA E FONTES (MOVIDO DO IDENTIDADE) -->
                    <div style="background: white; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); border: 1px solid #e2e8f0; padding: 25px; margin-bottom: 20px;">
                        <div class="section-header"><h3>Tipografia & Fontes Globais</h3></div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Fonte dos Títulos (Destaques/Itálicos)</label>
                                <select name="font_title" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0; font-weight: 500;">
                                    <% 
                                        const titleFonts = [
                                            'Playfair Display', 'Lora', 'Cinzel', 'Cormorant Garamond', 'Outfit', 'Inter Tight', 'Montserrat'
                                        ];
                                        const currentTitleFont = settings.font_title || 'Playfair Display';
                                    %>
                                    <% titleFonts.forEach(font => { %>
                                        <option value="<%= font %>" <%= font === currentTitleFont ? 'selected' : '' %>><%= font %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Fonte do Texto Principal (Leitura)</label>
                                <select name="font_body" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0; font-weight: 500;">
                                    <% 
                                        const bodyFonts = [
                                            'Inter Tight', 'Inter', 'Roboto', 'Open Sans', 'Montserrat', 'Lora'
                                        ];
                                        const currentBodyFont = settings.font_body || 'Inter Tight';
                                    %>
                                    <% bodyFonts.forEach(font => { %>
                                        <option value="<%= font %>" <%= font === currentBodyFont ? 'selected' : '' %>><%= font %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div class="section-header" style="margin-top: 30px;"><h3>Tamanhos dos Títulos (Responsivo)</h3></div>
                        <p class="field-note" style="margin-bottom: 15px;"><i class="ri-font-size"></i> Valores em rem. Ex: 4.0 equivale a um título grande; 2.2 fica melhor no celular.</p>
                        <div class="form-grid">
                            <% 
                                const titleSizeGroups = [
                                    { label: 'Hero Principal', key: 'hero', defaults: { desktop: 4, tablet: 3.1, mobile: 2.2 } },
                                    { label: 'Hero de Páginas Internas', key: 'page', defaults: { desktop: 3.2, tablet: 2.8, mobile: 2.3 } },
                                    { label: 'Títulos de Seção', key: 'section', defaults: { desktop: 3, tablet: 2.5, mobile: 2.1 } },
                                    { label: 'Títulos de Cards/Blocos', key: 'card', defaults: { desktop: 1.5, tablet: 1.35, mobile: 1.2 } }
                                ];
                                const devices = [
                                    { label: 'Desktop', key: 'desktop' },
                                    { label: 'Tablet', key: 'tablet' },
                                    { label: 'Mobile', key: 'mobile' }
                                ];
                            %>
                            <% titleSizeGroups.forEach(group => { %>
                                <div class="form-group full" style="margin-top: 10px; padding: 18px; background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 18px;">
                                    <label style="margin-bottom: 14px; display: block; font-weight: 700; color: var(--primary);"><%= group.label %></label>
                                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;">
                                        <% devices.forEach(device => { 
                                            const fieldName = `title_size_${group.key}_${device.key}`;
                                        %>
                                            <div>
                                                <span style="display: block; font-size: 0.68rem; font-weight: 900; color: #64748B; text-transform: uppercase; margin-bottom: 6px;"><%= device.label %></span>
                                                <input type="number" name="<%= fieldName %>" value="<%= settings[fieldName] || group.defaults[device.key] %>" min="0.8" max="8" step="0.1" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #CBD5E1; font-weight: 800;">
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <div id="tab-home-hero" class="tab-panel">
                    <div class="section-header"><h3>Home Page » Seção Hero</h3></div>
                    
                    <!-- CARROSSEL DE IMAGENS DO HERO -->
                    <div style="background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 20px; padding: 25px; margin-bottom: 25px;">
                        <h4 style="margin: 0 0 10px 0; font-size: 1rem; font-weight: 800; color: var(--primary); display: flex; align-items: center; gap: 8px;"><i class="ri-images-line"></i> Carrossel de Slides (Hero)</h4>
                        <p style="font-size: 0.75rem; color: #64748b; margin: 0 0 20px 0;">Configure até 5 slides com imagens independentes para Desktop, Tablet e Mobile, além de títulos, descrições e botões exclusivos para cada um.</p>
                        
                        <div id="hero-carousel-container" style="display: grid; gap: 20px; margin-bottom: 20px;">
                            <!-- Injetado por JavaScript -->
                        </div>

                        <button type="button" onclick="addHeroSlide()" id="add-hero-slide-btn" style="background: #10B981; color: white; border: none; padding: 10px 20px; border-radius: 10px; font-weight: 800; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; font-size: 0.75rem;">
                            <i class="ri-add-line"></i> Adicionar Slide
                        </button>
                        <input type="hidden" name="carousel_count" id="carousel_count_input" value="0">
                        <input type="hidden" name="hero_carousel_json" id="hero_carousel_json_input" value="<%= settings.hero_carousel_json || '' %>">
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Cor da Sobreposição (Overlay)</label>
                            <input type="color" name="hero_overlay_color" value="<%= settings.hero_overlay_color || '#0A1128' %>" style="width: 100%; height: 45px; padding: 5px; border-radius: 12px; border: 1px solid #E2E8F0; cursor: pointer;">
                        </div>
                        <div class="form-group">
                            <label>Opacidade do Overlay (0.00 a 1.00)</label>
                            <input type="number" name="hero_overlay_opacity" value="<%= settings.hero_overlay_opacity || 0.4 %>" step="0.05" min="0" max="1" style="padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0; width: 100%;">
                        </div>
                        <div class="form-group full">
                            <label>Posição Vertical do Título e Botão por Tela (px)</label>
                            <p class="field-note" style="margin-bottom: 16px;"><i class="ri-arrow-up-down-line"></i> Valor negativo sobe. Valor positivo desce. Desktop acima de 1024px, tablet até 1024px e mobile até 640px.</p>
                            <% 
                                const hasHeroValue = (value) => value !== null && typeof value !== 'undefined' && value !== '';
                                const heroTitleBase = hasHeroValue(settings.hero_title_offset_y) ? settings.hero_title_offset_y : 0;
                                const heroButtonBase = hasHeroValue(settings.hero_button_offset_y) ? settings.hero_button_offset_y : 0;
                                const heroPositionFields = [
                                    { label: 'Desktop', icon: 'ri-computer-line', suffix: 'desktop' },
                                    { label: 'Tablet', icon: 'ri-tablet-line', suffix: 'tablet' },
                                    { label: 'Mobile', icon: 'ri-smartphone-line', suffix: 'mobile' }
                                ];
                            %>
                            <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px;">
                                <% heroPositionFields.forEach(device => { 
                                    const titleKey = 'hero_title_offset_y_' + device.suffix;
                                    const buttonKey = 'hero_button_offset_y_' + device.suffix;
                                    const titleValue = hasHeroValue(settings[titleKey]) ? settings[titleKey] : heroTitleBase;
                                    const buttonValue = hasHeroValue(settings[buttonKey]) ? settings[buttonKey] : heroButtonBase;
                                %>
                                    <div style="background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 16px; padding: 16px;">
                                        <strong style="display: flex; align-items: center; gap: 8px; color: #0f172a; font-size: 0.85rem; margin-bottom: 12px;"><i class="<%= device.icon %>"></i> <%= device.label %></strong>
                                        <label style="font-size: 0.72rem; margin-bottom: 6px;">Título</label>
                                        <input type="number" name="<%= titleKey %>" value="<%= titleValue %>" step="5" min="-300" max="300" style="padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0; width: 100%; margin-bottom: 12px;">
                                        <label style="font-size: 0.72rem; margin-bottom: 6px;">Botão</label>
                                        <input type="number" name="<%= buttonKey %>" value="<%= buttonValue %>" step="5" min="-300" max="300" style="padding: 12px; border-radius: 12px; border: 1px solid #E2E8F0; width: 100%;">
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Card Flutuante: Título</label>
                            <input type="text" name="home_hero_card_title" value="<%= settings.home_hero_card_title || '' %>" placeholder="Sua empresa em <em>Crescimento</em>.">
                            <p class="field-note"><i class="ri-information-line"></i> Use &lt;em&gt;texto&lt;/em&gt; para aplicar a fonte alternada.</p>
                        </div>
                        <div class="form-group">
                            <label>Card Flutuante: Subtítulo (Link)</label>
                            <input type="text" name="home_hero_card_subtitle" value="<%= settings.home_hero_card_subtitle || '' %>" placeholder="Experiência Estratégica">
                        </div>
                    </div>
                </div>

                <div id="tab-home-sobre" class="tab-panel">
                    <div class="section-header"><h3>Home Page » Seção Sobre</h3></div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Título da Seção</label>
                            <input type="text" name="about_title" value="<%= settings.about_title %>">
                            <p class="field-note"><i class="ri-information-line"></i> Use &lt;em&gt;texto&lt;/em&gt; para aplicar a fonte alternada.</p>
                        </div>
                        <div class="form-group">
                            <label>Texto do Botão</label>
                            <input type="text" name="home_about_button_text" value="<%= settings.home_about_button_text %>">
                        </div>
                        <div class="form-group full">
                            <label>Resumo Institucional</label>
                            <textarea name="about_text"><%= settings.about_text %></textarea>
                        </div>
                        <div class="form-group full">
                            <label>Imagem de Destaque</label>
                            <input type="file" name="about_image_file" accept="image/*">
                            <input type="hidden" name="about_image" value="<%= settings.about_image %>">
                            <p class="field-note"><i class="ri-image-line"></i> Recomendado: Quadrado (1:1) 600x600px ou Proporção 4:3 (800x600px).</p>
                            <% if (settings.about_image) { %> <img src="<%= settings.about_image %>" class="img-preview"> <% } %>
                        </div>
                    </div>
                </div>

                <div id="tab-home-servicos" class="tab-panel">
                    <div class="section-header"><h3>Home Page » Seção Serviços</h3></div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Título da Seção</label>
                            <input type="text" name="services_section_title" value="<%= settings.services_section_title %>">
                            <p class="field-note"><i class="ri-information-line"></i> Use &lt;em&gt;texto&lt;/em&gt; para aplicar a fonte alternada.</p>
                        </div>

                        <div class="form-group full">
                            <label>Legenda / Apoio</label>
                            <input type="text" name="services_section_text" value="<%= settings.services_section_text %>">
                        </div>
                    </div>

                </div>

                <div id="tab-home-popup" class="tab-panel">
                    <div class="section-header"><h3>Customizar Pop-up de Detalhes (Modal)</h3></div>
                    
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Modelo / Layout do Pop-up</label>
                            <select name="popup_layout_model">
                                <option value="split" <%= settings.popup_layout_model === 'split' ? 'selected' : '' %>>Modelo Split (Imagem na Lateral esquerda / Topo no Mobile)</option>
                                <option value="top-image" <%= settings.popup_layout_model === 'top-image' ? 'selected' : '' %>>Modelo Centralizado (Imagem no Topo / Centralizado)</option>
                                <option value="no-image" <%= settings.popup_layout_model === 'no-image' ? 'selected' : '' %>>Modelo Minimalista (Sem Imagem / Foco no Texto)</option>
                            </select>
                            <p class="field-note"><i class="ri-information-line"></i> Selecione a estrutura geral do pop-up ao abrir um serviço.</p>
                        </div>

                        <div class="form-group">
                            <label>Cor de Fundo do Pop-up</label>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <input type="color" name="color_popup_bg" value="<%= settings.color_popup_bg || '#FFFFFF' %>" style="width: 50px; height: 40px; padding: 0; border: none; cursor: pointer; border-radius: 8px;">
                                <input type="text" value="<%= settings.color_popup_bg || '#FFFFFF' %>" style="flex: 1;" oninput="this.previousElementSibling.value = this.value">
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Cor do Título do Pop-up</label>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <input type="color" name="color_popup_title" value="<%= settings.color_popup_title || '#0A1128' %>" style="width: 50px; height: 40px; padding: 0; border: none; cursor: pointer; border-radius: 8px;">
                                <input type="text" value="<%= settings.color_popup_title || '#0A1128' %>" style="flex: 1;" oninput="this.previousElementSibling.value = this.value">
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Cor do Texto do Pop-up</label>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <input type="color" name="color_popup_text" value="<%= settings.color_popup_text || '#333333' %>" style="width: 50px; height: 40px; padding: 0; border: none; cursor: pointer; border-radius: 8px;">
                                <input type="text" value="<%= settings.color_popup_text || '#333333' %>" style="flex: 1;" oninput="this.previousElementSibling.value = this.value">
                            </div>
                        </div>

                        <div class="form-group">
