                                        <label style="font-size: 0.65rem; color: #ef4444; font-weight: 700; cursor: pointer;">
                                            <input type="checkbox" name="carousel_mobile_${index}_remove" value="1"> Remover
                                        </label>
                                    </div>` : ''}
                            </div>
                        </div>
                        <div style="display: grid; gap: 10px;">
                            <div>
                                <label style="font-size: 0.7rem; font-weight: 700; color: #475569; display: block; margin-bottom: 2px;">Título do Slide</label>
                                <input type="text" name="carousel_title_${index}" value="${(slide.title || '').replace(/"/g, '&quot;')}" placeholder="Título de impacto" style="padding: 8px; font-size: 0.75rem; width: 100%; border: 1px solid #cbd5e1; border-radius: 6px;">
                            </div>
                            <div>
                                <label style="font-size: 0.7rem; font-weight: 700; color: #475569; display: block; margin-bottom: 2px;">Modelo de Layout (Grid)</label>
                                <select name="carousel_layout_style_${index}" style="padding: 8px; font-size: 0.75rem; width: 100%; border: 1px solid #cbd5e1; border-radius: 6px; font-weight: 600;">
                                    <option value="classic" ${slide.layout_style === 'classic' || !slide.layout_style ? 'selected' : ''}>Clássico (Texto à esquerda, Fundo completo)</option>
                                    <option value="split" ${slide.layout_style === 'split' ? 'selected' : ''}>Split (Texto esquerda 50%, Imagem direita 50%)</option>
                                    <option value="centered" ${slide.layout_style === 'centered' ? 'selected' : ''}>Centralizado (Texto focado no meio)</option>
                                </select>
                            </div>
                            <div>
                                <label style="font-size: 0.7rem; font-weight: 700; color: #475569; display: block; margin-bottom: 2px;">Texto do Botão</label>
                                <input type="text" name="carousel_button_text_${index}" value="${(slide.button_text || '').replace(/"/g, '&quot;')}" placeholder="Texto do botão" style="padding: 8px; font-size: 0.75rem; width: 100%; border: 1px solid #cbd5e1; border-radius: 6px;">
                            </div>
                            <div>
                                <label style="font-size: 0.7rem; font-weight: 700; color: #475569; display: block; margin-bottom: 2px;">Descrição Secundária</label>
                                <textarea name="carousel_description_${index}" placeholder="Descrição do slide" style="padding: 8px; font-size: 0.75rem; width: 100%; border: 1px solid #cbd5e1; border-radius: 6px; min-height: 50px;">${slide.description || ''}</textarea>
                            </div>
                        </div>
                    </div>
                `;
                container.appendChild(item);
            });

            document.getElementById('carousel_count_input').value = heroSlides.length;
            document.getElementById('hero_carousel_json_input').value = JSON.stringify(heroSlides);

            // Controlar estado do botão Adicionar
            const addBtn = document.getElementById('add-hero-slide-btn');
            if (addBtn) addBtn.disabled = heroSlides.length >= 5;
        }

        window.addHeroSlide = function() {
            if (heroSlides.length >= 5) return;
            heroSlides.push({ image_desktop: '', image_tablet: '', image_mobile: '', title: '', description: '', button_text: '' });
            renderHeroSlides();
        };

        window.removeHeroSlide = function(index) {
            heroSlides.splice(index, 1);
            renderHeroSlides();
        };

        renderHeroSlides();

        renderLayoutBuilder();
    </script>

    <!-- LISTA DE SUGESTÕES DE ÍCONES (REMOVIDA DAQUI) -->
</body>
</html>
