            layoutSecoes = rawLayout ? JSON.parse(rawLayout) : [...defaultSections];
            defaultSections.forEach(defSec => {
                if (!layoutSecoes.find(s => s.id === defSec.id)) {
                    const defIdx = defaultSections.findIndex(s => s.id === defSec.id);
                    if (defIdx > 0) {
                        const predecessorId = defaultSections[defIdx - 1].id;
                        const targetIdx = layoutSecoes.findIndex(s => s.id === predecessorId);
                        if (targetIdx !== -1) {
                            layoutSecoes.splice(targetIdx + 1, 0, defSec);
                            return;
                        }
