<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | ARQUÊΔ</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body style="display: flex;">
    <%- include('../partials/admin-sidebar') %>
    
    <main>
        <div class="card-cms" style="max-width: 1000px; margin: 0 auto;">
            <header style="margin-bottom: 50px; border-bottom: 2px solid #F1F5F9; padding-bottom: 30px;">
                <h1><%= service ? 'Refinar' : 'Arquitetar' %> Solução <em>Estratégica</em></h1>
                <p class="subtitle">Expanda o portfólio de autoridade da ARQUÊΔ com precisão tática.</p>
            </header>

            <form action="<%= service ? '/admin/servicos/editar/' + service.id : '/admin/servicos' %>" method="POST" enctype="multipart/form-data">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Título da Solução</label>
                        <input type="text" name="titulo" placeholder="Ex: Diagnóstico Cultural 360°" required onkeyup="generateSlug(this.value)" value="<%= service ? service.titulo : '' %>">
                    </div>
                    <div class="form-group">
                        <label>Slug (URL Estratégica)</label>
                        <input type="text" name="slug" id="slugInput" required value="<%= service ? service.slug : '' %>">
                    </div>

                    <div class="form-group">
                        <label>Ícone Representativo (RemixIcon)</label>
                        <input type="text" name="icone" placeholder="ri-team-line" required value="<%= service ? service.icone : '' %>">
                    </div>
                    <div class="form-group">
                        <label>Mídia de Capa (Upload)</label>
                        <input type="file" name="imagem_file" accept="image/*">
                        <input type="hidden" name="imagem" value="<%= service ? service.imagem : '' %>">
                        <% if (service && service.imagem) { %>
                            <img src="<%= service.imagem %>" class="img-preview">
                        <% } %>
                    </div>

                    <div class="form-group full">
                        <label>Resumo Executivo (Card de Seleção)</label>
                        <textarea name="resumo" placeholder="Descreva o valor imediato desta solução em até 3 linhas..." required><%= service ? service.resumo : '' %></textarea>
                    </div>

                    <div class="form-group full">
                        <label>Metodologia Detalhada (Conteúdo Principal)</label>
                        <textarea name="conteudo" style="height: 250px;" placeholder="Estruture a entrega técnica, benefícios e processos..." required><%= service ? service.conteudo : '' %></textarea>
                    </div>
                </div>

                <div style="margin-top: 50px; padding: 40px; background: #F8FAFC; border-radius: 30px; border: 1px solid var(--border);">
                    <h4 style="font-size: 0.9rem; font-weight: 900; color: var(--primary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 25px; display: flex; align-items: center; gap: 10px;">
                        <i class="ri-search-eye-line" style="color: var(--accent);"></i> Otimização SEO (Motores de Pesquisa)
                    </h4>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Meta Title (Título da Aba)</label>
                            <input type="text" name="meta_title" placeholder="Título que aparece no Google..." value="<%= service ? service.meta_title : '' %>">
                        </div>
                        <div class="form-group">
                            <label>Meta Description (Resumo SEO)</label>
                            <textarea name="meta_description" style="height: 100px;" placeholder="Descritivo estratégico para indexação..."><%= service ? service.meta_description : '' %></textarea>
                        </div>
                    </div>
                </div>

                <!-- Governança de Exibição -->
                <div style="margin-top: 50px; padding: 40px; background: #FFF; border-radius: 30px; border: 1px solid var(--border);">
                    <h4 style="font-size: 0.9rem; font-weight: 900; color: var(--primary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 25px; display: flex; align-items: center; gap: 10px;">
                        <i class="ri-layout-grid-line" style="color: var(--accent);"></i> Governança de Exibição
                    </h4>
                    <div class="form-grid">
                        <div class="form-group" style="display: flex; align-items: center; gap: 15px;">
                            <input type="hidden" name="destaque_home" value="0">
                            <input type="checkbox" name="destaque_home" value="1" <%= service && service.destaque_home ? 'checked' : '' %> style="width: auto; height: auto;">
                            <label style="margin-bottom: 0;">Exibir em Destaque na Home?</label>
                        </div>
                        <div class="form-group" style="display: flex; align-items: center; gap: 15px;">
                            <input type="hidden" name="ativo" value="0">
                            <input type="checkbox" name="ativo" value="1" <%= !service || service.ativo ? 'checked' : '' %> style="width: auto; height: auto;">
                            <label style="margin-bottom: 0;">Solução Ativa (Páginas de Listagem)?</label>
                        </div>
                        <div class="form-group">
                            <label>Ordem de Exibição (Numérica)</label>
                            <input type="number" name="ordem" value="<%= service ? service.ordem : 0 %>">
                        </div>
                    </div>
                </div>

                <div style="margin-top: 50px; display: flex; gap: 20px;">
                    <button type="submit" class="btn-premium btn-primary" style="flex: 1;">
                        <i class="ri-save-3-line"></i> <%= service ? 'SALVAR ALTERAÇÕES' : 'PUBLICAR SOLUÇÃO' %>
                    </button>
                    <a href="/admin/servicos" class="btn-premium" style="background: #E2E8F0; color: #475569;">CANCELAR</a>
                </div>
            </form>
        </div>
    </main>

    <script>
        function generateSlug(text) {
            const slug = text.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^\w ]+/g, '').replace(/ +/g, '-');
            document.getElementById('slugInput').value = slug;
        }
    </script>
</body>
</html>
