<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | ARQUÊΔ</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body style="display: flex;">
    <%- include('../partials/admin-sidebar') %>
    
    <main>
        <div class="card-cms" style="max-width: 800px; margin: 0 auto;">
            <header style="margin-bottom: 50px; text-align: center; border-bottom: 2px solid #F1F5F9; padding-bottom: 30px;">
                <a href="/admin/equipe" style="text-decoration: none; color: var(--text-muted); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 20px;"><i class="ri-arrow-left-line"></i> VOLTAR PARA LISTAGEM</a>
                <h1><%= member ? 'Refinar' : 'Integrar' %> <em>Membro</em></h1>
                <p class="subtitle">Gestão do capital humano e autoridade estratégica da ARQUÊΔ.</p>
            </header>

            <form action="<%= member ? '/admin/equipe/editar/' + member.id : '/admin/equipe' %>" method="POST" enctype="multipart/form-data">
                
                <div style="text-align: center; margin-bottom: 40px; background: #F8FAFC; padding: 40px; border-radius: 30px; border: 1px dashed var(--border);">
                    <img id="imgPreview" src="<%= member ? member.imagem : '/img/placeholder-user.png' %>" 
                         style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 5px solid white; box-shadow: 0 10px 25px rgba(0,0,0,0.1); margin-bottom: 20px;">
                    
                    <input type="file" name="imagem_file" id="fileInput" accept="image/*" style="display: none;">
                    <button type="button" onclick="document.getElementById('fileInput').click()" 
                            style="display: block; width: 220px; margin: 0 auto; background: var(--primary); color: white; border: none; padding: 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 900; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; transition: 0.3s;">
                        <i class="ri-camera-lens-line"></i> ALTERAR FOTOGRAFIA
                    </button>
                    <input type="hidden" name="imagem" value="<%= member ? member.imagem : '' %>">
                </div>

                <div class="form-grid">
                    <div class="form-group full">
                        <label>Nome Completo do Consultor</label>
                        <input type="text" name="nome" value="<%= member ? member.nome : '' %>" required placeholder="Ex: Dr. Marcus Albuquerque">
                    </div>

                    <div class="form-group">
                        <label>Função / Cargo Estratégico</label>
                        <input type="text" name="funcao" value="<%= member ? member.funcao : '' %>" required placeholder="Ex: Sócio Diretor & Estrategista">
                    </div>

                    <div class="form-group">
                        <label>Ordem de Precedência (Prioridade)</label>
                        <input type="number" name="ordem" value="<%= member ? member.ordem : 0 %>" placeholder="0">
                        <span style="font-size: 0.7rem; color: var(--text-muted); display: block; margin-top: 8px;">Números menores definem maior prioridade de exibição.</span>
                    </div>
                </div>

                <button type="submit" class="btn-premium btn-primary" style="width: 100%; margin-top: 50px; justify-content: center;">
                    <i class="ri-save-3-line"></i> <%= member ? 'SALVAR ALTERAÇÕES' : 'INTEGRAR À EQUIPE' %>
                </button>
            </form>
        </div>
    </main>

    <script>
        document.getElementById('fileInput').onchange = function (evt) {
            const [file] = evt.target.files;
            if (file) {
                document.getElementById('imgPreview').src = URL.createObjectURL(file);
            }
        }
    </script>
</body>
</html>
