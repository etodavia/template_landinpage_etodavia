<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | ARQUÊΔ</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
</head>
<body style="display: flex;">
    <%- include('../partials/admin-sidebar') %>
    
    <main>
        <div class="card-cms">
            <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px;">
                <div>
                    <h1>Gestão de <em>Equipe</em></h1>
                    <p class="subtitle">Controle o capital humano e a autoridade exibida no site.</p>
                </div>
                <a href="/admin/equipe/novo" class="btn-premium btn-accent"><i class="ri-user-add-line"></i> ADICIONAR MEMBRO</a>
            </header>

            <%- include('../partials/admin-alerts') %>

            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 80px;">Avatar</th>
                            <th>Nome do Consultor</th>
                            <th>Função Estratégica</th>
                            <th style="width: 80px; text-align: center;">Ordem</th>
                            <th style="width: 120px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (members.length === 0) { %>
                            <tr>
                                <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 60px;">Nenhum membro cadastrado.</td>
                            </tr>
                        <% } %>
                        <% members.forEach(m => { %>
                            <tr>
                                <td>
                                    <img src="<%= m.imagem || '/img/placeholder-user.png' %>" 
                                         style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid #F1F5F9;">
                                </td>
                                <td><strong style="color: var(--primary);"><%= m.nome %></strong></td>
                                <td><span style="font-weight: 600; color: #666;"><%= m.funcao %></span></td>
                                <td style="text-align: center;"><span style="background: #F1F5F9; padding: 4px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 800;"><%= m.ordem %></span></td>
                                <td>
                                    <div class="actions">
                                        <a href="/admin/equipe/editar/<%= m.id %>" class="btn-action btn-edit" title="Refinar"><i class="ri-pencil-line"></i></a>
                                        <form action="/admin/equipe/delete/<%= m.id %>" method="POST" onsubmit="return confirm('Remover este consultor?')">
                                            <button type="submit" class="btn-action btn-delete" title="Excluir"><i class="ri-delete-bin-line"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>
