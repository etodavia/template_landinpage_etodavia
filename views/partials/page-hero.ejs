<%
    const pageHeroDesktop = locals.image || "/img/hero_optimo.png";
    const pageHeroTablet = locals.imageTablet || pageHeroDesktop;
    const pageHeroMobile = locals.imageMobile || pageHeroTablet;
    const pageHeroOverlay = 'linear-gradient(rgba(10, 17, 40, 0.4), rgba(10, 17, 40, 0.8))';
%>
<section class="page-hero responsive-bg" style="--responsive-bg-desktop: <%= pageHeroOverlay %>, url('<%= pageHeroDesktop %>'); --responsive-bg-tablet: <%= pageHeroOverlay %>, url('<%= pageHeroTablet %>'); --responsive-bg-mobile: <%= pageHeroOverlay %>, url('<%= pageHeroMobile %>');">
    <div class="container">
        <div class="page-hero-content">
            <span class="section-label" data-reveal style="color: white; opacity: 0.6;">Consultoria Boutique Sistema</span>
            <h1 data-reveal style="color: white;">
                <% if (pageTitle.includes('<em>')) { %>
                    <%- pageTitle %>
                <% } else { %>
                    <% 
                        const words = pageTitle.split(' ');
                        if (words.length > 1) {
                            const lastWord = words.pop();
                            const rest = words.join(' ');
                    %>
                        <%= rest %> <em><%= lastWord %></em>
                    <% } else { %>
                        <%= pageTitle %>
                    <% } %>
                <% } %>
            </h1>
        </div>
    </div>
</section>
